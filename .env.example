# Frontend env vars (NOT committed to git — see .gitignore)
# Copy this file to .env for local dev

# API host (origin only is OK — code appends /api for REST). Examples:
#   VITE_API_URL=http://localhost:5000
#   VITE_API_URL=https://gp4-dse-game-production.up.railway.app
VITE_API_URL=https://gp4-dse-game-production.up.railway.app

# Backend URL for Vite proxy (local dev only)
VITE_BACKEND_URL=http://localhost:5000
