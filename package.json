    "lucide-react": "^0.577.0",
    "openai": "^5.12.2",
    "phaser": "^3.90.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "socket.io": "^4.8.0",
